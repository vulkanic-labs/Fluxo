{
  "name": "fluxo",
  "displayName": "Fluxo: Visual Workflow Builder",
  "version": "0.0.1",
  "description": "Create custom browser logic with Fluxo's intuitive block-based interface. Connect triggers, actions, and conditions to automate your daily web routine.",
  "author": "vulcaniclabs",
  "scripts": {
    "dev": "plasmo dev",  
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@types/webextension-polyfill": "^0.12.5",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "<all_urls>"
    ],
    "permissions": [
      "tabs",
      "proxy",
      "alarms",
      "storage",
      "debugger",
      "activeTab",
      "offscreen",
      "webNavigation",
      "unlimitedStorage",
      "scripting"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "fluxo@extension",
        "strict_min_version": "91.1.0"
      }
    }
  }
}
